# Automatic HTTPS when DOMAIN is a real domain (set ACME_EMAIL in .env).
# For local testing: DOMAIN=localhost (HTTP only).

{
	email {$ACME_EMAIL}
}

{$DOMAIN:localhost} {
	encode gzip
	request_body {
		max_size 25MB
	}

	@uploads path /uploads/*
	handle @uploads {
		reverse_proxy app:3000
		header Cache-Control "public, max-age=31536000, immutable"
	}

	@static path /_next/static/*
	handle @static {
		reverse_proxy app:3000
		header Cache-Control "public, max-age=31536000, immutable"
	}

	reverse_proxy app:3000
}
