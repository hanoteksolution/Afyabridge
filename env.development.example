# Local development — copy to .env automatically via: npm run setup
# Or manually: cp env.development.example .env

NODE_ENV=development

# Filled automatically after `npm run db:dev` / setup (do not edit port by hand)
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=placeholder"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:51217/template1?sslmode=disable"

NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_SECRET="afya-bridge-local-dev-change-me"

# Production caches CMS data; dev always fetches fresh (see src/lib/cms.ts)
# CMS_REVALIDATE_SECONDS=120
