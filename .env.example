# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (DigitalOcean Droplet) — WordPress-simple setup
# ═══════════════════════════════════════════════════════════════════════════
#
# On the server:
#   1. git clone <your-repo>
#   2. cd Afyabridge
#   3. bash scripts/install-production.sh
#
# That is it — Docker installs the app, database, and HTTPS automatically.
# No extra packages, no Prisma dev, no manual migrations.
#
# Manual alternative:
#   cp .env.example .env   (fill in values below)
#   docker compose up -d --build
#
# Default admin (first run only): admin@afyabridge.com / admin123

DOMAIN=your-domain.com
ACME_EMAIL=you@your-domain.com

POSTGRES_USER=afya
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=afya

NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
AUTH_SECRET=replace-with-openssl-rand-base64-32

NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT (your PC only — do not use on the server)
# ═══════════════════════════════════════════════════════════════════════════
#
# npm install
# npm run dev
#
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:51217/template1?sslmode=disable"
# NEXTAUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
