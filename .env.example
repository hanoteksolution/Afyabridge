# ═══════════════════════════════════════════════════════════════════════════
# LOCAL DEVELOPMENT — team members after git clone
# ═══════════════════════════════════════════════════════════════════════════
#
#   npm run setup     ← one command: install + DB + seed
#   npm run dev
#
# Or copy manually:  cp env.development.example .env
#
# See README.md and env.development.example for local values.

# ═══════════════════════════════════════════════════════════════════════════
# PRODUCTION (DigitalOcean Droplet) — see DEPLOY.md for server team
# ═══════════════════════════════════════════════════════════════════════════

DOMAIN=your-domain.com
ACME_EMAIL=you@your-domain.com

POSTGRES_USER=afya
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=afya

NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com
AUTH_SECRET=replace-with-openssl-rand-base64-32

NODE_ENV=production

# Public page cache TTL (seconds). Admin edits bust cache immediately.
CMS_REVALIDATE_SECONDS=120

# Local dev vars are in env.development.example (use npm run setup)
